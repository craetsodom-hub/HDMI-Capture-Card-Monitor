<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FF11141A</Color>
    <Color x:Key="SurfaceColor">#FF1C212A</Color>
    <Color x:Key="SurfaceSecondaryColor">#FF242A35</Color>
    <Color x:Key="PreviewColor">#FF080A0E</Color>
    <Color x:Key="PrimaryTextColor">#FFF2F5FA</Color>
    <Color x:Key="MutedTextColor">#FFB7C0CF</Color>
    <Color x:Key="SubtleTextColor">#FF9DA8BA</Color>
    <Color x:Key="AccentColor">#FF68A5FF</Color>
    <Color x:Key="AccentHoverColor">#FF82B5FF</Color>
    <Color x:Key="AccentPressedColor">#FF4C8FEF</Color>
    <Color x:Key="BorderColor">#FF39414E</Color>
    <Color x:Key="FocusColor">#FF91BFFF</Color>
    <Color x:Key="StatusIdleColor">#FF9EABBE</Color>
    <Color x:Key="SuccessColor">#FF51C88D</Color>
    <Color x:Key="WarningColor">#FFFFB45D</Color>
    <Color x:Key="DangerColor">#FFFF7B82</Color>
    <Color x:Key="DisabledSurfaceColor">#FF2B313C</Color>
    <Color x:Key="DisabledTextColor">#FF8993A3</Color>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondaryColor}" />
    <SolidColorBrush x:Key="PreviewBrush" Color="{StaticResource PreviewColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource SubtleTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource FocusColor}" />
    <SolidColorBrush x:Key="StatusIdleBrush" Color="{StaticResource StatusIdleColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="{StaticResource DisabledSurfaceColor}" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />
</ResourceDictionary>
