<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FF17191E</Color><Color x:Key="SurfaceColor">#FF242830</Color><Color x:Key="PreviewColor">#FF0D0F13</Color><Color x:Key="PrimaryTextColor">#FFF3F5F8</Color><Color x:Key="MutedTextColor">#FFB3BECD</Color><Color x:Key="AccentColor">#FF6CA6FF</Color><Color x:Key="BorderColor">#FF3B424E</Color><Color x:Key="StatusIdleColor">#FFA7B1C1</Color>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" /><SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" /><SolidColorBrush x:Key="PreviewBrush" Color="{StaticResource PreviewColor}" /><SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" /><SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" /><SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" /><SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" /><SolidColorBrush x:Key="StatusIdleBrush" Color="{StaticResource StatusIdleColor}" />
</ResourceDictionary>
