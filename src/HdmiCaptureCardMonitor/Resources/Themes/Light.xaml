<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FFF4F6F9</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceSecondaryColor">#FFF8F9FC</Color>
    <Color x:Key="PreviewColor">#FF101319</Color>
    <Color x:Key="PrimaryTextColor">#FF172033</Color>
    <Color x:Key="MutedTextColor">#FF566176</Color>
    <Color x:Key="SubtleTextColor">#FF6E788A</Color>
    <Color x:Key="AccentColor">#FF1769E0</Color>
    <Color x:Key="AccentHoverColor">#FF0E5BC8</Color>
    <Color x:Key="AccentPressedColor">#FF0A4DAA</Color>
    <Color x:Key="BorderColor">#FFD8DEE8</Color>
    <Color x:Key="FocusColor">#FF0B63CE</Color>
    <Color x:Key="StatusIdleColor">#FF66758D</Color>
    <Color x:Key="SuccessColor">#FF138A55</Color>
    <Color x:Key="WarningColor">#FFB25B00</Color>
    <Color x:Key="DangerColor">#FFC9343E</Color>
    <Color x:Key="DisabledSurfaceColor">#FFE9EDF3</Color>
    <Color x:Key="DisabledTextColor">#FF747E8E</Color>
    <Color x:Key="DisabledBorderColor">#FFC8D0DC</Color>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondaryColor}" />
    <SolidColorBrush x:Key="PreviewBrush" Color="{StaticResource PreviewColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource SubtleTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource FocusColor}" />
    <SolidColorBrush x:Key="StatusIdleBrush" Color="{StaticResource StatusIdleColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="{StaticResource DisabledSurfaceColor}" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />
    <SolidColorBrush x:Key="DisabledBorderBrush" Color="{StaticResource DisabledBorderColor}" />
</ResourceDictionary>
