<Window x:Class="HdmiCaptureCardMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="HDMI Capture Card Monitor"
        Width="1100" Height="700" MinWidth="820" MinHeight="540"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <DockPanel Margin="24">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="HDMI Capture Card Monitor" Style="{StaticResource TitleText}" />
                <TextBlock Text="Monitor-first capture preview" Style="{StaticResource SubtitleText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="Settings" Command="{Binding ShowSettingsInformationCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Content="Help" Command="{Binding ShowHelpInformationCommand}" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>
        <Border Style="{StaticResource PreviewSurface}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
                    <TextBlock Text="No capture device selected" Style="{StaticResource PreviewMessage}" TextAlignment="Center" />
                    <TextBlock Text="Connect a compatible USB HDMI capture card. Device discovery and preview are planned for later phases."
                               Style="{StaticResource PreviewDescription}" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid DockPanel.Dock="Bottom" Margin="0,20,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="DEVICE" Style="{StaticResource FieldLabel}" />
                <ComboBox IsEnabled="False" SelectedIndex="0" Style="{StaticResource SelectorControl}"><ComboBoxItem Content="No device available" /></ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock Text="FORMAT" Style="{StaticResource FieldLabel}" />
                <ComboBox IsEnabled="False" SelectedIndex="0" Style="{StaticResource SelectorControl}"><ComboBoxItem Content="Select a device first" /></ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,0">
                <Button Content="Start" IsEnabled="False" Style="{StaticResource PrimaryButton}" />
                <Button Content="Fullscreen" IsEnabled="False" Style="{StaticResource SecondaryButton}" />
                <Button Content="Snapshot" IsEnabled="False" Style="{StaticResource SecondaryButton}" />
                <Button Content="Record" IsEnabled="False" Style="{StaticResource RecordButton}" />
            </StackPanel>
        </Grid>
        <Border DockPanel.Dock="Bottom" Style="{StaticResource StatusBar}" Margin="0,16,0,0">
            <DockPanel>
                <Ellipse Width="8" Height="8" Fill="{DynamicResource StatusIdleBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding SessionStateDisplay}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
