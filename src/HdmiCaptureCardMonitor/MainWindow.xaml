<Window x:Class="HdmiCaptureCardMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="HDMI Capture Card Monitor"
        Width="1100" Height="700" MinWidth="820" MinHeight="540"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="160" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="HDMI Capture Card Monitor" Style="{StaticResource TitleText}" />
                <TextBlock Text="Monitor-first capture preview" Style="{StaticResource SubtitleText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="Settings" Command="{Binding ShowSettingsInformationCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Content="Help" Command="{Binding ShowHelpInformationCommand}" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource PreviewSurface}" Margin="0,0,0,20">
            <Grid>
                <StackPanel MaxWidth="520" Margin="32" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PreviewTitle}" Style="{StaticResource PreviewMessage}" TextAlignment="Center" />
                    <TextBlock Text="{Binding PreviewDescription}"
                               Style="{StaticResource PreviewDescription}" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshDevicesCommand}" IsEnabled="{Binding CanRefreshDevices}" Style="{StaticResource SecondaryButton}" AutomationProperties.Name="Refresh video devices" />
                        <TextBlock Text="DEVICE" Style="{StaticResource FieldLabel}" />
                    </DockPanel>
                    <ComboBox ItemsSource="{Binding Devices}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedDevice}" Text="{Binding DevicePlaceholder}" IsEditable="True" IsReadOnly="True" IsEnabled="{Binding HasDevices}" Style="{StaticResource SelectorControl}" AutomationProperties.Name="Video capture device" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Text="FORMAT" Style="{StaticResource FieldLabel}" />
                    <ComboBox ItemsSource="{Binding Formats}" DisplayMemberPath="DisplayLabel" SelectedItem="{Binding SelectedFormat}" Text="{Binding FormatPlaceholder}" IsEditable="True" IsReadOnly="True" IsEnabled="{Binding HasFormats}" Style="{StaticResource SelectorControl}" AutomationProperties.Name="Native video format" />
                </StackPanel>
            </Grid>
            <WrapPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Right">
                <Button Content="Start" IsEnabled="False" Style="{StaticResource PrimaryButton}" />
                <Button Content="Fullscreen" IsEnabled="False" Style="{StaticResource SecondaryButton}" />
                <Button Content="Snapshot" IsEnabled="False" Style="{StaticResource SecondaryButton}" />
                <Button Content="Record" IsEnabled="False" Style="{StaticResource RecordButton}" />
            </WrapPanel>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource StatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{DynamicResource StatusIdleBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding SessionStateDisplay}" Margin="16,0,0,0" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
