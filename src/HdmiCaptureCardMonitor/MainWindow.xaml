<Window x:Class="HdmiCaptureCardMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HdmiCaptureCardMonitor.Controls"
        xmlns:presentation="clr-namespace:HdmiCaptureCardMonitor.Presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HDMI Capture Card Monitor"
        Width="{StaticResource WindowDefaultWidth}" Height="{StaticResource WindowDefaultHeight}"
        MinWidth="{StaticResource WindowMinimumWidth}" MinHeight="{StaticResource WindowMinimumHeight}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        PreviewKeyDown="OnPreviewKeyDown"
        AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.MainWindow}">
    <Grid x:Name="RootGrid" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Margin" Value="{StaticResource PagePadding}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsFullscreenPresentation}" Value="True">
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Black" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid x:Name="MainContent" IsEnabled="{Binding IsMainContentEnabled}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="{StaticResource PreviewMinimumHeight}" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Grid x:Name="ProductHeader" Grid.Row="0" Margin="{StaticResource SectionGapBottom}" Visibility="{Binding IsWindowedChromeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="{StaticResource HeaderIconSize}" Height="{StaticResource HeaderIconSize}" CornerRadius="{StaticResource RadiusMedium}" Background="{DynamicResource AccentBrush}" Margin="{StaticResource HeaderIconGap}" AutomationProperties.Name="Application icon">
                <Viewbox Width="{StaticResource HeaderGlyphSize}" Height="{StaticResource HeaderGlyphSize}">
                    <Canvas Width="24" Height="24">
                        <Path Fill="White" Data="M3,4 L21,4 L21,17 L14,17 L14,19 L18,19 L18,21 L6,21 L6,19 L10,19 L10,17 L3,17 Z M5,6 L5,15 L19,15 L19,6 Z" />
                        <Path Fill="White" Data="M9,9 L15,12 L9,15 Z" />
                    </Canvas>
                </Viewbox>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="HDMI Capture Card Monitor" Style="{StaticResource TitleText}" />
                <TextBlock Text="A focused monitor for USB video capture" Style="{StaticResource SubtitleText}" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="SettingsButton" Content="Se_ttings" Command="{Binding ShowSettingsInformationCommand}" Style="{StaticResource QuietButton}" Margin="{StaticResource FieldGapRight}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.Settings}" ToolTip="Open settings information" />
                <Button x:Name="HelpButton" Content="_Help" Command="{Binding ShowHelpInformationCommand}" Style="{StaticResource QuietButton}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.Help}" ToolTip="Open help" />
            </StackPanel>
        </Grid>

        <Border x:Name="PreviewFrame" Grid.Row="1" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.PreviewArea}">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource PreviewSurface}">
                    <Setter Property="Margin" Value="{StaticResource SectionGapBottom}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullscreenPresentation}" Value="True">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="Background" Value="Black" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <controls:HwndPreviewSurface x:Name="PreviewHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Focusable="False" />
                <StackPanel MaxWidth="{StaticResource PreviewMessageMaxWidth}" Margin="{StaticResource PreviewContentPadding}" HorizontalAlignment="Center" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewMessageVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding PreviewGlyph}" Style="{StaticResource PreviewGlyph}" AutomationProperties.Name="Preview state icon" />
                    <TextBlock Text="{Binding PreviewTitle}" Style="{StaticResource PreviewMessage}" TextAlignment="Center" />
                    <TextBlock Text="{Binding PreviewDescription}" Style="{StaticResource PreviewDescription}" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ConfigurationCard" Grid.Row="2" Style="{StaticResource Card}" Margin="{StaticResource CardToStatusGap}" Visibility="{Binding IsWindowedChromeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid x:Name="ConfigurationGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="DeviceColumn" Width="*" />
                        <ColumnDefinition x:Name="ConfigurationGapColumn" Width="{StaticResource ControlGapLength}" />
                        <ColumnDefinition x:Name="FormatColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="DevicePanel">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="_Refresh" Command="{Binding RefreshDevicesCommand}" IsEnabled="{Binding CanRefreshDevices}" Style="{StaticResource QuietButton}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.RefreshDevices}" ToolTip="Scan for video devices again" />
                            <Label Content="_Device" Target="{Binding ElementName=DeviceSelector}" Style="{StaticResource FieldLabelControl}" />
                        </DockPanel>
                        <Grid>
                            <ComboBox x:Name="DeviceSelector" ItemsSource="{Binding Devices}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedDevice}" IsEnabled="{Binding HasDevices}" Style="{StaticResource SelectorControl}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.DeviceSelector}" ToolTip="{Binding SelectedItem.DisplayName, ElementName=DeviceSelector}">
                                <ComboBox.ItemContainerStyle><Style TargetType="ComboBoxItem" BasedOn="{StaticResource SelectorItemStyle}"><Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}" /></Style></ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <TextBlock Text="{Binding DevicePlaceholder}" IsHitTestVisible="False" Margin="{StaticResource SelectorPlaceholderPadding}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, ElementName=DeviceSelector}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                            <DataTrigger Binding="{Binding IsEnabled, ElementName=DeviceSelector}" Value="False"><Setter Property="Opacity" Value="0.74" /></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="FormatPanel" Grid.Column="2">
                        <Label Content="_Format" Target="{Binding ElementName=FormatSelector}" Style="{StaticResource FieldLabelControl}" />
                        <Grid>
                            <ComboBox x:Name="FormatSelector" ItemsSource="{Binding Formats}" DisplayMemberPath="DisplayLabel" SelectedItem="{Binding SelectedFormat}" IsEnabled="{Binding HasFormats}" Style="{StaticResource SelectorControl}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.FormatSelector}" ToolTip="{Binding SelectedItem.DisplayLabel, ElementName=FormatSelector}">
                                <ComboBox.ItemContainerStyle><Style TargetType="ComboBoxItem" BasedOn="{StaticResource SelectorItemStyle}"><Setter Property="AutomationProperties.Name" Value="{Binding DisplayLabel}" /></Style></ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <TextBlock Text="{Binding FormatPlaceholder}" IsHitTestVisible="False" Margin="{StaticResource SelectorPlaceholderPadding}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, ElementName=FormatSelector}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                            <DataTrigger Binding="{Binding IsEnabled, ElementName=FormatSelector}" Value="False"><Setter Property="Opacity" Value="0.74" /></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ActionGrid" Grid.Row="1" Margin="{StaticResource SectionGapTop}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="ActionDescription" VerticalAlignment="Center">
                        <TextBlock Text="Preview controls" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding PreviewControlHint}" Style="{StaticResource SubtitleText}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel x:Name="ActionButtons" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="StartStopButton" Content="{Binding StartStopAccessText}" Command="{Binding TogglePreviewCommand}" Style="{StaticResource PrimaryButton}" Margin="{StaticResource ControlGapRight}" VerticalAlignment="Bottom" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.StartStopPreview}" />
                        <Button x:Name="FullscreenButton" Content="{Binding FullscreenAccessText}" Command="{Binding ToggleFullscreenCommand}" IsEnabled="{Binding CanToggleFullscreen}" Style="{StaticResource SecondaryButton}" Margin="{StaticResource ControlGapRight}" VerticalAlignment="Bottom" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.Fullscreen}" ToolTip="Enter or exit fullscreen monitor mode (F11)" />
                        <StackPanel x:Name="UpcomingActions">
                            <TextBlock Text="UPCOMING" Style="{StaticResource FieldLabel}" HorizontalAlignment="Stretch" TextAlignment="Center" />
                            <WrapPanel>
                                <Button Content="Snapshot" IsEnabled="False" Style="{StaticResource UpcomingButton}" Margin="{StaticResource ControlGapRight}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.SnapshotUpcoming}" ToolTip="Upcoming feature" />
                                <Button Content="Record" IsEnabled="False" Style="{StaticResource UpcomingButton}" AutomationProperties.Name="{x:Static presentation:UiAutomationLabels.RecordUpcoming}" ToolTip="Upcoming feature" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="LifecycleStatusBar" Grid.Row="3" Style="{StaticResource StatusBar}" Visibility="{Binding IsWindowedChromeVisible, Converter={StaticResource BooleanToVisibilityConverter}}" AutomationProperties.LiveSetting="Polite">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="{StaticResource Space8}" Height="{StaticResource Space8}" Margin="{StaticResource StatusDotGap}" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource StatusIdleBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SessionStateDisplay}" Value="Previewing"><Setter Property="Fill" Value="{DynamicResource SuccessBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding SessionStateDisplay}" Value="Error"><Setter Property="Fill" Value="{DynamicResource DangerBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding SessionStateDisplay}" Value="Starting"><Setter Property="Fill" Value="{DynamicResource WarningBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding SessionStateDisplay}" Value="Stopping"><Setter Property="Fill" Value="{DynamicResource WarningBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusMessage}" />
                <Border Grid.Column="2" Margin="{StaticResource StatusBadgeGap}" Padding="{StaticResource StatusBadgePadding}" CornerRadius="{StaticResource RadiusSmall}" Background="{DynamicResource SurfaceSecondaryBrush}">
                    <TextBlock Text="{Binding SessionStateDisplay}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Border>
            </Grid>
        </Border>

        </Grid>

        <Border Panel.ZIndex="50" Style="{StaticResource DialogOverlay}" Visibility="{Binding IsInformationDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}" AutomationProperties.Name="Information dialog overlay">
            <Border Width="{StaticResource DialogWidth}" MaxWidth="{StaticResource DialogWidth}" Margin="{StaticResource DialogMargin}" Padding="{StaticResource DialogPadding}" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Card}" AutomationProperties.Name="{Binding InformationDialogTitle}" KeyboardNavigation.TabNavigation="Cycle">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding InformationDialogEyebrow}" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="{Binding InformationDialogTitle}" Style="{StaticResource DialogTitle}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Command="{Binding CloseInformationDialogCommand}" Style="{StaticResource QuietButton}" AutomationProperties.Name="Close information dialog" />
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding InformationDialogDescription}" Margin="{StaticResource DialogSectionGap}" TextWrapping="Wrap" LineHeight="{StaticResource BodyLineHeight}" />
                    <TextBlock Grid.Row="2" Text="{Binding InformationDialogDetails}" Margin="{StaticResource DialogSectionGap}" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" LineHeight="{StaticResource BodyLineHeight}" />
                    <Button x:Name="DialogPrimaryButton" Grid.Row="3" Content="_Got it" Command="{Binding CloseInformationDialogCommand}" Margin="{StaticResource DialogActionGap}" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}" AutomationProperties.Name="Close information dialog" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
